# Venice API — https://docs.venice.ai/api-reference/api-spec
# Get your key: https://venice.ai/settings/api
VENICE_API_KEY=

# Optional: override base URL (default: https://api.venice.ai/api/v1)
# VENICE_API_BASE_URL=https://api.venice.ai/api/v1

# Optional: override transcription endpoint (default: {VENICE_API_BASE_URL}/audio/transcriptions)
# Use the Audio → Transcription endpoint, not chat/completions.
# VENICE_TRANSCRIBE_ENDPOINT=

# Model for structuring the memory (default: venice-uncensored)
VENICE_MODEL=venice-uncensored

# Model for transcribing audio. Must be an ASR (speech-to-text) model, not a text chat model.
# If unset, the app fetches the first ASR model from Venice (GET /models?type=asr).
VENICE_TRANSCRIBE_MODEL=tts-kokoro

# If you get "spawn ... ffmpeg ENOENT", set this to your ffmpeg binary (e.g. from Homebrew):
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
